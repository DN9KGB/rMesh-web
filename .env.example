# Docker Compose Umgebungsvariablen
# Kopieren nach .env und anpassen

# Domain für Traefik-Labels
DOMAIN=rmesh.de

DB_NAME=rmesh
DB_USER=rmesh
DB_PASS=sicheres_passwort

DB_ROOT_PASSWORD=sicheres_root_passwort

# bcrypt-Hash erzeugen: php -r "echo password_hash('deinPasswort', PASSWORD_DEFAULT);"
ADMIN_PASS_HASH=$2y$12$...